<component type="desktop-application">
  <id>io.github.ea4k.klog</id>

  <name>KLog</name>
  <summary>Amateur radio logging program</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.ea4k">
    <name>Jaime Robles (EA4K)</name>
  </developer>

  <description>
    <p>
      KLog is a free, multiplatform ham radio logger. It helps amateur radio
      operators keep track of their QSOs (contacts), manage awards such as DXCC
      and WAS, import and export ADIF files, and upload logs to LoTW, eQSL,
      ClubLog and QRZ.com.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Full ADIF 3.1.4 support for import and export</li>
      <li>DXCC, WAZ, WAS and other award tracking</li>
      <li>Integration with LoTW, eQSL, ClubLog and QRZ.com</li>
      <li>DX-Cluster client</li>
      <li>Satellite QSO support</li>
      <li>Hamlib rig control</li>
      <li>WSJT-X / JTDX UDP integration</li>
      <li>Built-in DXCC entity and CQ zone database</li>
      <li>QSO statistics and charts</li>
    </ul>
  </description>

  <launchable type="desktop-id">klog.desktop</launchable>

  <url type="homepage">https://github.com/ea4k/klog</url>
  <url type="bugtracker">https://github.com/ea4k/klog/issues</url>
  <url type="vcs-browser">https://github.com/ea4k/klog</url>

  <provides>
    <binary>klog</binary>
  </provides>

  <content_rating type="oars-1.1" />

  <categories>
    <category>Utility</category>
    <category>HamRadio</category>
  </categories>

  <keywords>
    <keyword>ham</keyword>
    <keyword>radio</keyword>
    <keyword>amateur</keyword>
    <keyword>log</keyword>
    <keyword>qso</keyword>
    <keyword>adif</keyword>
    <keyword>dxcc</keyword>
    <keyword>lotw</keyword>
  </keywords>

  <screenshots>
