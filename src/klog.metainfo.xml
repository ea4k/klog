      <caption>KLog main window showing the QSO entry and log view</caption>
      <image>https://user-images.githubusercontent.com/29511627/103910279-f1009b80-5104-11eb-9b30-83e436528c56.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="2.5" date="2025-01-01">
